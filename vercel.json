{
  "version": 2,
  "functions": {
    "api/process-job.py": {
      "runtime": "vercel-python@3.0.9"
    }
  },
  "buildCommand": "cd botjobs-web && pnpm install && pnpm run build",
  "outputDirectory": "botjobs-web/dist",
  "rewrites": [
    {
      "source": "/api/process-job",
      "destination": "/api/process-job.py"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}