{
  "version": 2,
  "functions": {
    "api/process-job.py": {
      "runtime": "vercel-python@3.0.9"
    }
  },
  "buildCommand": "cd botjobs-web && pnpm install && vite build --outDir dist",
  "outputDirectory": "botjobs-web/dist",
  "routes": [
    {
      "src": "/api/process-job",
      "dest": "/api/process-job.py"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}