{
  "version": 2,
  "builds": [
    {
      "src": "botjobs-web/package.json",
      "use": "@vercel/static-build"
    },
    {
      "src": "api/process-job.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/process",
      "dest": "api/process-job.py"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}