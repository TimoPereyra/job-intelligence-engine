{
  "version": 2,
  "builds": [
    {
      "src": "botjobs-web/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/process-job.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/process",
      "dest": "api/process-job.py"
    },
    {
      "src": "/assets/(.*)",
      "dest": "botjobs-web/dist/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "botjobs-web/dist/$1"
    }
  ]
}